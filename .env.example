# ============================================================
# GrowSMM — Environment variables (Vercel)
# Copy to .env.local for local dev, or set them in
# Vercel → Project → Settings → Environment Variables.
# ============================================================

# ---------- Firebase Admin (server-side) ----------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the full private key. Newlines can be written as \n
# (the functions call .replace(/\\n/g, "\n") on load).
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=
FIREBASE_STORAGE_BUCKET=

# ---------- Firebase Web (returned by /api/client-config) ----------
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
FIREBASE_AUTH_USE_SAME_SITE=

# ---------- Site ----------
SITE_URL=
# Vercel auto-sets VERCEL_URL; these are kept for parity with legacy code
URL=
DEPLOY_PRIME_URL=

# ---------- Shared secrets (protect internal endpoints) ----------
AUTO_SYNC_SECRET=
AUTO_PAYMENT_CONFIRM_SECRET=
CRON_SECRET_KEY=
ORDER_SYNC_SECRET=
PANEL_SYNC_SECRET=
STATUS_CHECK_SECRET=

# ---------- Auto-payment / UPI ----------
AUTO_UPI_ID=
AUTO_UPI_NAME=
AUTO_CONFIRM_URL=
PUBLIC_USD_RATE=

# ---------- Gmail watcher (payment confirmation via email) ----------
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_IMAP_USER=
GMAIL_IMAP_APP_PASSWORD=
GMAIL_FROM_MATCH=
GMAIL_SEARCH_HINT=
GMAIL_CREDIT_KEYWORDS=
GMAIL_FETCH_LIMIT=
GMAIL_MESSAGE_MAX_AGE_SEC=
AUTO_GMAIL_POLL_MS=

# ---------- Optional: GitHub-hosted background watcher ----------
ENABLE_GITHUB_WATCHER=false
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_WORKFLOW_FILE=run-watcher.yml
GITHUB_REF=main
GITHUB_TOKEN=

# ---------- Misc ----------
ALLOW_LOCAL_PY_FALLBACK=false
